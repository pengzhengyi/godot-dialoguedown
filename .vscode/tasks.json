{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "restore",
      "type": "shell",
      "command": "dotnet restore DialogueSystem.sln",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build",
      "type": "shell",
      "command": "dotnet build DialogueSystem.sln --configuration Release --no-restore",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "restore",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "type": "shell",
      "command": "dotnet test DialogueSystem.sln --configuration Release --no-build",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "dependsOn": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "docs: lint oss markdown",
      "type": "shell",
      "command": "markdownlint README.md CONTRIBUTING.md CODE_OF_CONDUCT.md SECURITY.md CHANGELOG.md .github/pull_request_template.md",
      "problemMatcher": []
    },
    {
      "label": "docs: check links",
      "type": "shell",
      "command": "lychee --no-progress --timeout 10 README.md CONTRIBUTING.md CODE_OF_CONDUCT.md SECURITY.md CHANGELOG.md .github/pull_request_template.md",
      "problemMatcher": []
    }
  ]
}
