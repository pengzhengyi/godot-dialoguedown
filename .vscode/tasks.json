{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "restore",
      "type": "shell",
      "command": "dotnet restore DialogueDown.sln",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build",
      "detail": ".NET: build the solution (Release).",
      "type": "shell",
      "command": "dotnet build DialogueDown.sln --configuration Release --no-restore",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "restore",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build: fast",
      "detail": ".NET inner loop: build Release without analyzers (run restore once first; never substitutes for the full build).",
      "type": "shell",
      "command": "dotnet build DialogueDown.sln --configuration Release --no-restore -p:RunAnalyzers=false",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "detail": ".NET: run the test suite.",
      "type": "shell",
      "command": "dotnet test DialogueDown.sln --configuration Release --no-build",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "dependsOn": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test: project",
      "detail": ".NET inner loop: run one already-built test project.",
      "type": "shell",
      "command": "dotnet test ${input:dotnetTestProject} --configuration Release --no-build --no-restore",
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test: filter",
      "detail": ".NET inner loop: run a dotnet test filter in one already-built project.",
      "type": "shell",
      "command": "dotnet test ${input:dotnetTestProject} --configuration Release --no-build --no-restore --filter \"${input:dotnetTestFilter}\"",
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "coverage",
      "detail": ".NET: run tests with coverage and generate a report.",
      "type": "shell",
      "command": "dotnet tool restore && dotnet test DialogueDown.sln --settings coverage.runsettings --collect:\"XPlat Code Coverage\" && dotnet reportgenerator \"-reports:tests/DialogueDown.Tests/TestResults/**/coverage.cobertura.xml\" \"-targetdir:coverage-report\" \"-reporttypes:Html;MarkdownSummary;Cobertura\"",
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "web: install",
      "detail": "Frontend: install pinned dependencies (npm ci).",
      "type": "shell",
      "command": "npm ci",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "web: build",
      "detail": "Frontend: build the single-file report (dist/report.html).",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "web: check",
      "detail": "Frontend: typecheck, lint, style, format, and unit tests (Vitest).",
      "type": "shell",
      "command": "npm run check",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "group": "test",
      "problemMatcher": ["$tsc", "$eslint-stylish"]
    },
    {
      "label": "web: test file",
      "detail": "Frontend inner loop: run one Vitest file.",
      "type": "shell",
      "command": "npm run test -- ${input:webVitestTarget}",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "web: test watch",
      "detail": "Frontend inner loop: watch one Vitest file.",
      "type": "shell",
      "command": "npm run test:watch -- ${input:webVitestTarget}",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "group": "test",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "web: e2e",
      "detail": "Frontend: Playwright end-to-end + accessibility tests (builds first).",
      "type": "shell",
      "command": "npm run e2e",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "dependsOn": "web: build",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "web: e2e file",
      "detail": "Frontend inner loop: run one static Playwright spec.",
      "type": "shell",
      "command": "npm run e2e -- ${input:webStaticE2ETarget}",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "web: e2e grep",
      "detail": "Frontend inner loop: run static Playwright tests matching a title.",
      "type": "shell",
      "command": "npm run e2e -- --grep \"${input:webPlaywrightGrep}\"",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "web: e2e live file",
      "detail": "Frontend inner loop: build the CLI once and run one live Playwright spec.",
      "type": "shell",
      "command": "npm run e2e:live -- ${input:webLiveE2ETarget}",
      "options": { "cwd": "${workspaceFolder}/src/DialogueDown.Visualization/web" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "build: all",
      "detail": "Build both the .NET solution and the web report.",
      "dependsOn": ["build", "web: build"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "verify: all",
      "detail": "Run every check: .NET tests, web check, and web e2e.",
      "dependsOn": ["test", "web: check", "web: e2e"],
      "dependsOrder": "sequence",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "clean",
      "detail": "Remove build/test artifacts (keeps node_modules and the committed report).",
      "type": "shell",
      "command": "dotnet clean DialogueDown.sln --nologo && rm -rf coverage-report TestResults src/DialogueDown.Visualization/web/playwright-report src/DialogueDown.Visualization/web/test-results src/DialogueDown.Visualization/web/coverage src/DialogueDown.Visualization/web/.vite src/DialogueDown.Visualization/web/.cache",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "docs: lint oss markdown",
      "type": "shell",
      "command": "markdownlint README.md CONTRIBUTING.md CODE_OF_CONDUCT.md SECURITY.md CHANGELOG.md .github/pull_request_template.md",
      "problemMatcher": []
    },
    {
      "label": "docs: check links",
      "type": "shell",
      "command": "lychee --no-progress --timeout 10 README.md CONTRIBUTING.md CODE_OF_CONDUCT.md SECURITY.md CHANGELOG.md .github/pull_request_template.md",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "dotnetTestProject",
      "type": "pickString",
      "description": "Test project",
      "options": [
        "tests/DialogueDown.Tests/DialogueDown.Tests.csproj",
        "tests/DialogueDown.ConfigurationLoader.Tests/DialogueDown.ConfigurationLoader.Tests.csproj",
        "tests/DialogueDown.Cli.Tests/DialogueDown.Cli.Tests.csproj",
        "tests/DialogueDown.Visualization.Tests/DialogueDown.Visualization.Tests.csproj",
        "tests/DialogueDown.Visualization.Live.Tests/DialogueDown.Visualization.Live.Tests.csproj",
        "tests/DialogueDown.Architecture.Tests/DialogueDown.Architecture.Tests.csproj"
      ],
      "default": "tests/DialogueDown.Tests/DialogueDown.Tests.csproj"
    },
    {
      "id": "dotnetTestFilter",
      "type": "promptString",
      "description": "dotnet test filter (for example: FullyQualifiedName~TextTests)",
      "default": "FullyQualifiedName~"
    },
    {
      "id": "webVitestTarget",
      "type": "promptString",
      "description": "Vitest file",
      "default": "src/editor-completions.test.ts"
    },
    {
      "id": "webStaticE2ETarget",
      "type": "promptString",
      "description": "Static Playwright spec",
      "default": "e2e/autocomplete.spec.ts"
    },
    {
      "id": "webPlaywrightGrep",
      "type": "promptString",
      "description": "Static Playwright test-title pattern",
      "default": "completes a known speaker"
    },
    {
      "id": "webLiveE2ETarget",
      "type": "promptString",
      "description": "Live Playwright spec",
      "default": "e2e-live/semantic-autocomplete.spec.ts"
    }
  ]
}
