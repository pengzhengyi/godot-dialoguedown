{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../src/DialogueDown",
          "files": ["**/*.csproj"]
        }
      ],
      "dest": "api",
      "namespaceLayout": "nested",
      "memberLayout": "separatePages"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**", "demo/**", "**/bin/**", "**/obj/**"]
      }
    ],
    "resource": [
      {
        "files": ["guide/assets/**", "logo.svg", "logo-pipeline.svg"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern", "template"],
    "globalMetadata": {
      "_appName": "DialogueDown",
      "_appTitle": "DialogueDown docs",
      "_appLogoPath": "logo.svg",
      "_appFaviconPath": "logo.svg",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/pengzhengyi/godot-dialoguedown",
        "branch": "main"
      }
    }
  }
}
