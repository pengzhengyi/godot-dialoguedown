{
  "name": "dialoguedown-visualization",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript client for the DialogueDown compilation-visualization report, bundled by Vite into a single self-contained HTML the .NET library embeds.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && VITE_ENTRY=launcher vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --check .",
    "check": "npm run typecheck && npm run lint:js && npm run lint:css && npm run format && npm run test",
    "e2e:live": "playwright test --config playwright.live.config.ts"
  },
  "dependencies": {
    "@picocss/pico": "^2.0.6",
    "d3": "^7.9.0",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2",
    "marked-gfm-heading-id": "^3.2.0",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.46.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.3",
    "stylelint": "^16.8.0",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.1.0",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.0.1",
    "vitest": "^4.1.10"
  }
}
